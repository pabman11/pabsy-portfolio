---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Instagram, Github, Linkedin } from "@/assets/icons";
const socialLinks = [
    {
        name: "Instagram",
        icon: Instagram,
        url: "https://instagram.com/pabman11",
    },
    {
        name: "GitHub",
        icon: Github,
        url: "https://github.com/pabman11",
    },
    {
        name: "LinkedIn",
        icon: Linkedin,
        url: "https://www.linkedin.com/in/pablo-fornali-manzanas/",
    },
];
---

<BaseLayout
    title="Contacto - Pablo Fornali"
    description="Ponte en contacto conmigo para colaboraciones, proyectos o simplemente para charlar."
>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="mb-12">
            <p class="text-xs text-zinc-600 font-semibold tracking-widest uppercase mb-4">Contacto</p>
            <h1 class="text-5xl md:text-6xl font-bold text-zinc-50 tracking-tighter leading-none">
                Hablemos.
            </h1>
            <p class="text-zinc-400 mt-4 max-w-md leading-relaxed">
                ¿Tienes alguna pregunta o propuesta? Me encantaría escucharte.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-zinc-900 border border-zinc-800 p-6 rounded-xl">
                <h3 class="text-sm font-semibold text-zinc-500 uppercase tracking-widest mb-3">Email</h3>
                <a
                    href="mailto:hola@pabsy.dev"
                    class="text-zinc-50 hover:text-primary transition-colors text-lg font-medium"
                >
                    hola@pabsy.dev
                </a>
            </div>

            <div class="bg-zinc-900 border border-zinc-800 p-6 rounded-xl">
                <h3 class="text-sm font-semibold text-zinc-500 uppercase tracking-widest mb-3">
                    Redes sociales
                </h3>
                <div class="flex flex-col gap-3">
                    {
                        socialLinks.map((link) => (
                            <a
                                href={link.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex items-center gap-2 text-zinc-400 hover:text-zinc-50 transition-colors text-sm font-medium"
                            >
                                <span class="inline-block align-middle text-zinc-600">
                                    <link.icon width="16" height="16" />
                                </span>
                                <span>{link.name}</span>
                            </a>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>
</BaseLayout>
