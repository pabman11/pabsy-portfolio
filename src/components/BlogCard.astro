---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  description: string;
  pubDate: string;
  cover: ImageMetadata;
  coverAlt: string;
  tags: string[];
  slug: string;
}

const { title, description, pubDate, cover, coverAlt, tags, slug } = Astro.props;

const formattedDate = new Date(pubDate).toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<article class="group bg-zinc-900 rounded-xl overflow-hidden border border-zinc-800 hover:border-zinc-700 transition-all duration-300">
  <a href={`/blog/${slug}`} class="block">
    <div class="overflow-hidden">
      <Image
        src={cover}
        alt={coverAlt}
        class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-500"
        widths={[400, 600]}
        sizes="(max-width: 768px) 400px, 600px"
      />
    </div>
    <div class="p-6">
      <time datetime={pubDate} class="text-xs text-zinc-600 font-medium">{formattedDate}</time>
      <h3 class="text-zinc-50 font-semibold mt-2 mb-2 group-hover:text-primary transition-colors leading-snug">
        {title}
      </h3>
      <p class="text-zinc-500 text-sm mb-4 line-clamp-3 leading-relaxed">
        {description}
      </p>
      <div class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="text-xs px-2 py-1 bg-zinc-800 text-zinc-500 rounded-md">
            {tag}
          </span>
        ))}
      </div>
    </div>
  </a>
</article>
