---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  description: string;
  image: ImageMetadata;
  imageAlt: string;
  technologies: string[];
  liveUrl?: string;
  githubUrl?: string;
}

const { title, description, image, imageAlt, technologies, liveUrl, githubUrl } = Astro.props;
---

<article class="group bg-zinc-900 rounded-xl overflow-hidden border border-zinc-800 hover:border-zinc-700 transition-all duration-300">
  <div class="overflow-hidden">
    <Image
      src={image}
      alt={imageAlt}
      class="w-full h-64 object-cover group-hover:scale-105 transition-transform duration-500"
      widths={[400, 600, 800]}
      sizes="(max-width: 768px) 400px, (max-width: 1024px) 600px, 800px"
    />
  </div>
  <div class="p-6">
    <h3 class="text-xl font-semibold text-zinc-50 mb-2 group-hover:text-primary transition-colors">
      {title}
    </h3>
    <p class="text-zinc-500 text-sm mb-4 leading-relaxed">
      {description}
    </p>
    <div class="flex flex-wrap gap-2 mb-5">
      {technologies.map((tech) => (
        <span class="text-xs px-2 py-1 bg-zinc-800 text-zinc-400 rounded-md font-medium">
          {tech}
        </span>
      ))}
    </div>
    <div class="flex gap-4">
      {liveUrl && (
        <a
          href={liveUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-primary hover:text-primary-dark text-sm font-medium transition-colors"
        >
          Ver proyecto
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      )}
      {githubUrl && (
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-zinc-500 hover:text-zinc-50 text-sm font-medium transition-colors"
        >
          Código
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
      )}
    </div>
  </div>
</article>
