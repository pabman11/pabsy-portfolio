---
import { Image } from "astro:assets";
import { Github } from "@lucide/astro";
import { Rss } from "@lucide/astro";

interface Props {
    title: string;
    description: string;
    image: ImageMetadata;
    imageAlt: string;
    technologies: string[];
    liveUrl?: string;
    githubUrl?: string;
    blogPost?: string;
}

const {
    title,
    description,
    image,
    imageAlt,
    technologies,
    liveUrl,
    githubUrl,
    blogPost,
} = Astro.props;
---

<article
    class="group bg-zinc-900 rounded-xl overflow-hidden border border-zinc-800 hover:border-zinc-700 transition-all duration-300"
>
    <div class="overflow-hidden">
        <Image
            src={image}
            alt={imageAlt}
            class="w-full h-64 object-cover group-hover:scale-105 transition-transform duration-500"
            widths={[400, 600, 800]}
            sizes="(max-width: 768px) 400px, (max-width: 1024px) 600px, 800px"
        />
    </div>
    <div class="p-6">
        <h3
            class="text-xl font-semibold text-zinc-50 mb-2 group-hover:text-primary transition-colors"
        >
            {title}
        </h3>
        <p class="text-zinc-500 text-sm mb-4 leading-relaxed">
            {description}
        </p>
        <div class="flex flex-wrap gap-2 mb-5">
            {
                technologies.map((tech) => (
                    <span class="text-xs px-2 py-1 bg-zinc-800 text-zinc-400 rounded-md font-medium">
                        {tech}
                    </span>
                ))
            }
        </div>
        <div class="flex gap-4">
            {
                liveUrl && (
                    <a
                        href={liveUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-1.5 text-primary hover:text-primary-dark text-sm font-medium transition-colors"
                    >
                        Ver proyecto
                        <svg
                            class="w-3.5 h-3.5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="1.5"
                                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                            />
                        </svg>
                    </a>
                )
            }
            {
                githubUrl && (
                    <a
                        href={githubUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-1.5 text-primary hover:text-primary-dark text-sm font-medium transition-colors"
                    >
                        Código
                        <Github class="w-4 h-4 text-primary hover:text-primary-dark" />
                    </a>
                )
            }
            {
                blogPost && (
                    <a
                        href={blogPost}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-1.5 text-primary hover:text-primary-dark text-sm font-medium transition-colors"
                    >
                        Leer blog
                        <Rss class="w-4 h-4 text-primary hover:text-primary-dark" />
                    </a>
                )
            }
        </div>
    </div>
</article>
